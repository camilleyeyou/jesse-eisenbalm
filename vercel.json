          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https://kqyiauyahlmruyblxezp.supabase.co data:; connect-src 'self' https://jesse-eisenbalm-server.vercel.app; font-src 'self'"
        }
